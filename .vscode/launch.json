{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "GeoPort: Debug Current App",
      "type": "python",
      "request": "launch",
      "program": "${workspaceFolder}/src/main.py",
      "cwd": "${workspaceFolder}",
      "console": "integratedTerminal",
      "justMyCode": false,
      "envFile": "${workspaceFolder}/.env",
      "args": [
        "--no-browser"
      ]
    }
  ]
}
